local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")

print("[Xvlamer Hub] Death Farm Status: ON")

local running = true

local function fireButtonCompletely(btn)
    if not btn then return end
    pcall(function()
        btn.Visible = true
        btn.Active = true
        pcall(function() GuiService.SelectedObject = btn end)
        
        local events = {"MouseButton1Down", "MouseButton1Up", "MouseButton1Click", "Activated"}
        for _, eventName in ipairs(events) do
            if btn[eventName] then
                pcall(function() firesignal(btn[eventName]) end)
                pcall(function()
                    if getconnections then
                        for _, conn in ipairs(getconnections(btn[eventName])) do
                            conn:Fire()
                        end
                    end
                end)
            end
        end
        
        local absPos = btn.AbsolutePosition
        local absSize = btn.AbsoluteSize
        if absSize.X > 0 and absSize.Y > 0 then
            local centerX = absPos.X + (absSize.X / 2)
            local centerY = absPos.Y + (absSize.Y / 2)
            if VirtualInputManager then
                pcall(function()
                    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 1)
                    task.wait(0.04)
                    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 1)
                end)
            end
        end
    end)
end

task.spawn(function()
    while running do
        local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui", 2)
        if playerGui then
            local mainUi = playerGui:FindFirstChild("MainUI", true)
            if mainUi then
                local mainPlayBtn = mainUi:FindFirstChild("MainPlayButton", true)
                if mainPlayBtn and mainPlayBtn.Visible then
                    fireButtonCompletely(mainPlayBtn)
                    task.wait(0.15)
                end

                local hotelBtn = mainUi:FindFirstChild("Hotel", true)
                if hotelBtn and hotelBtn.Visible then
                    fireButtonCompletely(hotelBtn)
                    task.wait(0.15)
                end

                local confirmBtn = mainUi:FindFirstChild("Confirm", true)
                if confirmBtn and confirmBtn.Visible then
                    fireButtonCompletely(confirmBtn)
                    task.wait(0.3)
                end
            end
        end
        task.wait(0.3)
    end
end)

return function()
    running = false
    print("[Xvlamer Hub] Death Farm Status: OFF")
end
