local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local LOBBY_PLACE_ID = 6516141723

local function checkAndJoinLobby()
    -- Check if we are in the main lobby first before anything else
    if game.PlaceId ~= LOBBY_PLACE_ID then
        return false
    end

    task.spawn(function()
        local playerGui = LocalPlayer:WaitForChild("PlayerGui", 10)
        if not playerGui then return end
        local mainUi = playerGui:WaitForChild("MainUI", 10)
        if not mainUi then return end

        local function fireButton(btn)
            if btn then
                pcall(function()
                    btn.Visible = true
                end)
                pcall(function()
                    if getconnections then
                        for _, conn in ipairs(getconnections(btn.MouseButton1Click)) do
                            conn:Fire()
                        end
                    end
                end)
                pcall(function()
                    if firesignal then
                        firesignal(btn.MouseButton1Click)
                    end
                end)
            end
        end

        -- Find the 3 target buttons dynamically within MainUI
        local mainPlayBtn = mainUi:FindFirstChild("MainPlayButton", true)
        local hotelBtn = mainUi:FindFirstChild("Hotel", true)
        local confirmBtn = mainUi:FindFirstChild("Confirm", true)

        -- 1st: Click MainPlayButton
        if mainPlayBtn then
            fireButton(mainPlayBtn)
        end

        -- Minimal delay to ensure the game registers the first click before the next
        task.wait(0.05)

        -- 2nd: Click Hotel button
        if hotelBtn then
            fireButton(hotelBtn)
        end

        task.wait(0.05)

        -- 3rd: Click Confirm button
        if confirmBtn then
            fireButton(confirmBtn)
        end
    end)

    return true
end

-- Execute immediately when loaded via loadstring
return checkAndJoinLobby()
