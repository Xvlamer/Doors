local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualInputManager = game:GetService("VirtualInputManager")

print("[Xvlamer Hub] Death Farm Status: ON")

local running = true
local success = false

local function clickButton(btn)
    if not btn then return end
    pcall(function()
        btn.Visible = true
        btn.Active = true
        
        if firesignal then
            pcall(function() firesignal(btn.MouseButton1Click) end)
            pcall(function() firesignal(btn.Activated) end)
        end
        
        if getconnections then
            pcall(function()
                for _, conn in ipairs(getconnections(btn.MouseButton1Click)) do
                    conn:Fire()
                end
                for _, conn in ipairs(getconnections(btn.Activated)) do
                    conn:Fire()
                end
            end)
        end
        
        local absPos = btn.AbsolutePosition
        local absSize = btn.AbsoluteSize
        if absSize.X > 0 and absSize.Y > 0 then
            local centerX = absPos.X + (absSize.X / 2)
            local centerY = absPos.Y + (absSize.Y / 2)
            if VirtualInputManager then
                pcall(function()
                    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 1)
                    task.wait(0.05)
                    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 1)
                end)
            end
        end
    end)
end

task.spawn(function()
    while running and not success do
        local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if not playerGui or not running then break end
        
        local mainPlayBtn = playerGui:FindFirstChild("MainPlayButton", true)
        if mainPlayBtn and mainPlayBtn.Visible then
            clickButton(mainPlayBtn)
            task.wait(0.4)
            
            if not running then break end
            
            local hotelBtn = playerGui:FindFirstChild("Hotel", true)
            if hotelBtn and hotelBtn.Visible then
                clickButton(hotelBtn)
                task.wait(0.4)
                
                if not running then break end
                
                local confirmBtn = playerGui:FindFirstChild("Confirm", true)
                if confirmBtn and confirmBtn.Visible then
                    clickButton(confirmBtn)
                    task.wait(0.5)
                    
                    success = true
                    print("[Xvlamer Hub] Death Farm: Success. Stopping execution.")
                    break
                end
            end
        end
        
        task.wait(0.5)
    end
end)

return function()
    running = false
    print("[Xvlamer Hub] Death Farm Status: OFF")
end
