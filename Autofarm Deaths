local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer

local function clickButton(button)
    if not button then return end
    pcall(function()
        local pos = button.AbsolutePosition + (button.AbsoluteSize / 2)
        VirtualInputManager:SendMouseButtonEvent(pos.X, pos.Y + 36, 0, true, game, 0)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(pos.X, pos.Y + 36, 0, false, game, 0)
    end)
end

local function startDeathFarm()
    while true do
        task.wait(1)
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        
        if hum and hum.Health <= 0 then
            -- Wait for death screen elements to load in
            task.wait(1.5)
            
            local found = false
            for _, gui in ipairs(player.PlayerGui:GetDescendants()) do
                if gui:IsA("TextButton") or gui:IsA("ImageButton") then
                    local text = (gui:IsA("TextButton") and gui.Text:lower()) or ""
                    if text:find("again") or text:find("restart") or text:find("lobby") or text:find("revive") or text:find("respawn") then
                        clickButton(gui)
                        found = true
                        break
                    end
                end
            end
            
            -- Fallback if UI button wasn't matched immediately
            if not found then
                pcall(function()
                    if char:FindFirstChild("HumanoidRootPart") then
                        char.HumanoidRootPart:Destroy()
                    end
                end)
            end
            
            -- Wait for the player to successfully respawn before looping
            player.CharacterAdded:Wait()
            task.wait(2)
        end
    end
end

task.spawn(startDeathFarm)
