local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Player = Players.LocalPlayer

local function getGuiButton(name)
    local playerGui = Player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    local mainUI = playerGui:FindFirstChild("MainUI")
    if not mainUI then return nil end
    
    for _, descendant in ipairs(mainUI:GetDescendants()) do
        if descendant.Name == name and (descendant:IsA("GuiButton") or descendant:IsA("TextButton") or descendant:IsA("ImageButton")) then
            return descendant
        end
    end
    return nil
end

local function getMinesButton()
    local playerGui = Player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    local mainUI = playerGui:FindFirstChild("MainUI")
    if not mainUI then return nil end
    
    -- Exact hierarchy path: SidePanel -> Frames -> Floors -> List -> Mines
    local sidePanel = mainUI:FindFirstChild("SidePanel")
    if sidePanel then
        local frames = sidePanel:FindFirstChild("Frames")
        if frames then
            local floors = frames:FindFirstChild("Floors")
            if floors then
                local list = floors:FindFirstChild("List")
                if list then
                    local mines = list:FindFirstChild("Mines")
                    if mines then return mines end
                end
            end
        end
    end
    
    -- Fallback search
    for _, descendant in ipairs(mainUI:GetDescendants()) do
        if descendant:IsA("GuiButton") then
            local nameLower = descendant.Name:lower()
            local textLower = descendant.Text and descendant.Text:lower() or ""
            if nameLower:find("mine") or textLower:find("mine") or nameLower:find("floor2") or textLower:find("floor 2") then
                return descendant
            end
        end
    end
    return nil
end

local function clickButtonAccurately(btn)
    if not btn then return end
    pcall(function()
        local pos = btn.AbsolutePosition + (btn.AbsoluteSize / 2)
        VirtualInputManager:SendMouseButtonEvent(pos.X, pos.Y, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(pos.X, pos.Y, 0, false, game, 1)
    end)
end

