local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

local remotesFolder = ReplicatedStorage:WaitForChild("RemotesFolder", 5)
local statisticsRemote = remotesFolder and remotesFolder:WaitForChild("Statistics", 5)

getgenv().XvlamerStop_KnobFarm = false

task.spawn(function()
    while not getgenv().XvlamerStop_KnobFarm do
        pcall(function()
            local gold = LocalPlayer:FindFirstChild("Gold")
            if gold and gold.Value and gold.Value > 0 then
                if statisticsRemote then
                    statisticsRemote:FireServer()
                end
                if typeof(replicatesignal) == "function" then
                    replicatesignal(LocalPlayer.Kill)
                end
            end
        end)
        task.wait(0.05)
    end
end)
