local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")

local origLighting = {}
local origParticles = {}
local origTextures = {}
local origParts = {}
local origEffects = {}

local isOptimized = false
local optConnections = {}
local fogThread = nil

local function optimizeObj(v)
    if not v or not v.Parent then return end

    pcall(function()
        if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then
            if origParticles[v] == nil then
                origParticles[v] = v.Enabled
            end
            v.Enabled = false
        elseif v:IsA("PostEffect") or v:IsA("Atmosphere") then
            if origEffects[v] == nil then
                origEffects[v] = v.Enabled
            end
            v.Enabled = false
        elseif v:IsA("Decal") or v:IsA("Texture") then
            if origTextures[v] == nil then
                origTextures[v] = v.Transparency
            end
            v.Transparency = 1
        elseif v:IsA("MeshPart") then
            if origParts[v] == nil then
                origParts[v] = {Material = v.Material, TextureID = v.TextureID}
            end
            v.Material = Enum.Material.SmoothPlastic
            v.TextureID = ""
        elseif v:IsA("BasePart") then
            if origParts[v] == nil then
                origParts[v] = v.Material
            end
            v.Material = Enum.Material.SmoothPlastic
        end
    end)
end

local function applyOptimizations()
    if isOptimized then return end
    isOptimized = true

    origLighting = {
        Ambient = Lighting.Ambient,
        OutdoorAmbient = Lighting.OutdoorAmbient,
        Brightness = Lighting.Brightness,
        GlobalShadows = Lighting.GlobalShadows,
        FogEnd = Lighting.FogEnd,
        FogStart = Lighting.FogStart
    }

    Lighting.Ambient = Color3.fromRGB(235, 235, 235)
    Lighting.OutdoorAmbient = Color3.fromRGB(235, 235, 235)
    Lighting.Brightness = 1.8
    Lighting.GlobalShadows = false

    for _, v in ipairs(Workspace:GetDescendants()) do
        optimizeObj(v)
    end
    for _, v in ipairs(Lighting:GetChildren()) do
        optimizeObj(v)
    end

    local conn1 = Workspace.DescendantAdded:Connect(function(v)
        if isOptimized then optimizeObj(v) end
    end)
    local conn2 = Lighting.ChildAdded:Connect(function(v)
        if isOptimized then optimizeObj(v) end
    end)
    table.insert(optConnections, conn1)
    table.insert(optConnections, conn2)

    fogThread = task.spawn(function()
        while isOptimized do
            pcall(function()
                if Lighting.FogEnd < 100000 then
                    Lighting.FogStart = 0
                    Lighting.FogEnd = 9e9
                end
                for _, child in ipairs(Lighting:GetChildren()) do
                    if child:IsA("Atmosphere") and child.Enabled then
                        if origEffects[child] == nil then
                            origEffects[child] = true
                        end
                        child.Enabled = false
                    end
                end
            end)
            task.wait(0.3)
        end
    end)
end

local function revertOptimizations()
    if not isOptimized then return end
    isOptimized = false

    if fogThread then
        task.cancel(fogThread)
        fogThread = nil
    end

    for _, c in ipairs(optConnections) do
        pcall(function() c:Disconnect() end)
    end
    table.clear(optConnections)

    if origLighting.Ambient then
        Lighting.Ambient = origLighting.Ambient
        Lighting.OutdoorAmbient = origLighting.OutdoorAmbient
        Lighting.Brightness = origLighting.Brightness
        Lighting.GlobalShadows = origLighting.GlobalShadows
        Lighting.FogEnd = origLighting.FogEnd
        Lighting.FogStart = origLighting.FogStart
    end
    origLighting = {}

    for obj, enabled in pairs(origParticles) do
        if obj and obj.Parent then
            pcall(function() obj.Enabled = enabled end)
        end
    end
    origParticles = {}

    for obj, enabled in pairs(origEffects) do
        if obj and obj.Parent then
            pcall(function() obj.Enabled = enabled end)
        end
    end
    origEffects = {}

    for obj, transparency in pairs(origTextures) do
        if obj and obj.Parent then
            pcall(function() obj.Transparency = transparency end)
        end
    end
    origTextures = {}

    for obj, data in pairs(origParts) do
        if obj and obj.Parent then
            pcall(function()
                if type(data) == "table" then
                    obj.Material = data.Material
                    obj.TextureID = data.TextureID
                else
                    obj.Material = data
                end
            end)
        end
    end
    origParts = {}
end

return {
    Enable = applyOptimizations,
    Disable = revertOptimizations,
    Toggle = function(state)
        if state then
            applyOptimizations()
        else
            revertOptimizations()
        end
    end
}
