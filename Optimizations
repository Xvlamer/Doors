local Optimizer = {}

local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local isEnabled = false
local targetState = false
local isProcessing = false
local sweepToken = 0
local connections = {}

local cache = {
    props = {},
    surfaces = {},
    fx = {},
    lighting = {},
    terrain = {},
    quality = nil
}

setmetatable(cache.props, {__mode = "k"})
setmetatable(cache.surfaces, {__mode = "k"})
setmetatable(cache.fx, {__mode = "k"})

local function isExcluded(v)
    if not v then return true end
    
    local char = LocalPlayer.Character
    if char and (v == char or v:IsDescendantOf(char)) then
        return true
    end
    
    if v:IsA("Camera") or v:IsDescendantOf(Workspace:FindFirstChild("Camera")) then
        return true
    end

    if v:IsA("Tool") or v:IsDescendantOf(Workspace) and v:FindFirstAncestorOfClass("Tool") then
        return true
    end

    return false
end

local function applyOptimization(v)
    if isExcluded(v) then return end

    if v:IsA("BasePart") then
        if not cache.props[v] then
            cache.props[v] = {
                Material = v.Material,
                Reflectance = v.Reflectance,
                CastShadow = v.CastShadow,
                Color = v.Color,
                Transparency = v.Transparency
            }
        end
        pcall(function()
            v.Material = Enum.Material.SmoothPlastic
            v.Reflectance = 0
            v.CastShadow = false
        end)

    elseif v:IsA("SurfaceAppearance") then
        if not cache.surfaces[v] then
            cache.surfaces[v] = v.Parent
        end
        pcall(function() v.Parent = nil end)

    elseif v:IsA("Decal") or v:IsA("Texture") then
        if not cache.props[v] then
            cache.props[v] = { Transparency = v.Transparency, Parent = v.Parent }
        end
        pcall(function() 
            v.Transparency = 1 
            v.Parent = nil
        end)
        
    elseif v:IsA("PostEffect") or v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") or v:IsA("ColorCorrectionEffect") then
        if cache.fx[v] == nil then
            cache.fx[v] = v.Enabled
            pcall(function() v.Enabled = false end)
        end
    end
end

local function executeEnable(currentToken)
    isEnabled = true

    pcall(function()
        if cache.quality == nil then
            cache.quality = settings().Rendering.QualityLevel
        end
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)

    if next(cache.lighting) == nil then
        cache.lighting = {
            GlobalShadows = Lighting.GlobalShadows,
            EnvironmentSpecularScale = Lighting.EnvironmentSpecularScale,
            EnvironmentDiffuseScale = Lighting.EnvironmentDiffuseScale,
            Brightness = Lighting.Brightness,
            OutdoorAmbient = Lighting.OutdoorAmbient,
            FogEnd = Lighting.FogEnd,
            FogStart = Lighting.FogStart
        }
    end

    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.EnvironmentSpecularScale = 0
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.Brightness = 2
        Lighting.FogEnd = 999999
        Lighting.FogStart = 999999
    end)

    for _, v in pairs(Lighting:GetChildren()) do
        if not v:IsA("Sky") then
            applyOptimization(v)
        end
    end

    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain and next(cache.terrain) == nil then
        cache.terrain = {
            WaterWaveSize = terrain.WaterWaveSize,
            WaterWaveSpeed = terrain.WaterWaveSpeed,
            WaterReflectance = terrain.WaterReflectance,
            WaterTransparency = terrain.WaterTransparency,
            Decoration = terrain.Decoration
        }
        pcall(function()
            terrain.WaterWaveSize = 0
            terrain.WaterWaveSpeed = 0
            terrain.WaterReflectance = 0
            terrain.WaterTransparency = 0
            terrain.Decoration = false
        end)
    end

    -- Instantaneous full workspace sweep for maximum speed
    local descendants = Workspace:GetDescendants()
    for i = 1, #descendants do
        if not isEnabled or sweepToken ~= currentToken then break end
        applyOptimization(descendants[i])
    end

    if not connections.descendantAdded then
        connections.descendantAdded = Workspace.DescendantAdded:Connect(function(v)
            if isEnabled and sweepToken == currentToken then
                if not isExcluded(v) then
                    applyOptimization(v)
                end
            end
        end)
    end
end

local function executeDisable(currentToken)
    isEnabled = false

    if connections.descendantAdded then
        pcall(function() connections.descendantAdded:Disconnect() end)
        connections.descendantAdded = nil
    end

    pcall(function()
        if cache.quality then
            settings().Rendering.QualityLevel = cache.quality
        end
    end)

    for k, v in pairs(cache.lighting) do
        pcall(function() Lighting[k] = v end)
    end
    table.clear(cache.lighting)

    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        for k, v in pairs(cache.terrain) do
            pcall(function() terrain[k] = v end)
        end
    end
    table.clear(cache.terrain)

    for obj, props in pairs(cache.props) do
        if obj then
            if props.Parent and not obj.Parent then
                pcall(function() obj.Parent = props.Parent end)
            end
            for propName, propValue in pairs(props) do
                if propName ~= "Parent" then
                    pcall(function() obj[propName] = propValue end)
                end
            end
        end
    end
    table.clear(cache.props)

    for obj, oldParent in pairs(cache.surfaces) do
        if obj and oldParent then
            pcall(function() obj.Parent = oldParent end)
        end
    end
    table.clear(cache.surfaces)

    for obj, oldState in pairs(cache.fx) do
        if obj then
            pcall(function() obj.Enabled = oldState end)
        end
    end
    table.clear(cache.fx)
end

local function processQueue()
    if isProcessing then return end
    isProcessing = true

    while targetState ~= isEnabled do
        sweepToken = sweepToken + 1
        local currentToken = sweepToken
        
        if targetState then
            executeEnable(currentToken)
        else
            executeDisable(currentToken)
        end
    end

    isProcessing = false
end

function Optimizer.Toggle(state)
    local newState = state and true or false
    if targetState == newState then return end
    targetState = newState
    task.spawn(processQueue)
end

function Optimizer.Enable()
    Optimizer.Toggle(true)
end

function Optimizer.Disable()
    Optimizer.Toggle(false)
end

return Optimizer
