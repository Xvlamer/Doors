local Optimizer = {}

local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

local isEnabled = false
local targetState = false
local isProcessing = false
local sweepToken = 0
local connections = {}

local cache = {
    props = setmetatable({}, { __mode = "k" }),
    parents = setmetatable({}, { __mode = "k" }),
    fx = setmetatable({}, { __mode = "k" }),
    lighting = {},
    terrain = {},
    quality = nil
}

local targetMaterial = Enum.Material.SmoothPlastic
local camera = Workspace.CurrentCamera

local function isExcluded(v, char)
    if not v then return true end
    if char and (v == char or v:IsDescendantOf(char)) then return true end
    if v == camera or (camera and v:IsDescendantOf(camera)) then return true end
    if v:IsA("Tool") or v:FindFirstAncestorOfClass("Tool") then return true end
    return false
end

local function applyOptimization(v, char)
    if isExcluded(v, char) then return end
    
    if v:IsA("BasePart") then
        if not cache.props[v] then
            cache.props[v] = {
                Material = v.Material,
                Reflectance = v.Reflectance,
                CastShadow = v.CastShadow
            }
        end
        v.Material = targetMaterial
        v.Reflectance = 0
        v.CastShadow = false

    elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("SurfaceAppearance") or v:IsA("MeshPart") then
        if v:IsA("MeshPart") then
            -- Clear texture IDs on MeshParts to completely remove wrapped textures
            if not cache.props[v] then
                cache.props[v] = {
                    Material = v.Material,
                    Reflectance = v.Reflectance,
                    CastShadow = v.CastShadow,
                    TextureID = v.TextureID
                }
            end
            v.TextureID = ""
            v.Material = targetMaterial
            v.Reflectance = 0
            v.CastShadow = false
        else
            if not cache.parents[v] then 
                cache.parents[v] = v.Parent 
            end
            v.Parent = nil
        end

    elseif v:IsA("PostEffect") or v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") or v:IsA("ColorCorrectionEffect") or v:IsA("Atmosphere") or v:IsA("Sky") then
        if cache.fx[v] == nil then
            cache.fx[v] = v.Enabled
        end
        v.Enabled = false
    end
end

local function executeEnable(currentToken)
    isEnabled = true
    camera = Workspace.CurrentCamera

    if cache.quality == nil then
        cache.quality = settings().Rendering.QualityLevel
    end
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

    if next(cache.lighting) == nil then
        cache.lighting = {
            GlobalShadows = Lighting.GlobalShadows,
            EnvironmentSpecularScale = Lighting.EnvironmentSpecularScale,
            EnvironmentDiffuseScale = Lighting.EnvironmentDiffuseScale,
            Brightness = Lighting.Brightness,
            OutdoorAmbient = Lighting.OutdoorAmbient,
            Ambient = Lighting.Ambient,
            FogEnd = Lighting.FogEnd,
            FogStart = Lighting.FogStart
        }
    end

    -- Full bright, high ambient brightness, zero fog configuration
    Lighting.GlobalShadows = false
    Lighting.EnvironmentSpecularScale = 1
    Lighting.EnvironmentDiffuseScale = 1
    Lighting.Brightness = 3
    Lighting.OutdoorAmbient = Color3.fromRGB(220, 220, 220)
    Lighting.Ambient = Color3.fromRGB(220, 220, 220)
    Lighting.FogEnd = 9e9
    Lighting.FogStart = 9e9

    for _, v in ipairs(Lighting:GetChildren()) do
        applyOptimization(v, nil)
    end

    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain and next(cache.terrain) == nil then
        cache.terrain = {
            WaterWaveSize = terrain.WaterWaveSize,
            WaterWaveSpeed = terrain.WaterWaveSpeed,
            WaterReflectance = terrain.WaterReflectance,
            WaterTransparency = terrain.WaterTransparency,
            Decoration = terrain.Decoration
        }
        terrain.WaterWaveSize = 0
        terrain.WaterWaveSpeed = 0
        terrain.WaterReflectance = 0
        terrain.WaterTransparency = 0
        terrain.Decoration = false
    end

    local char = LocalPlayer.Character
    local descendants = Workspace:GetDescendants()
    
    task.spawn(function()
        local count = 0
        for i = 1, #descendants do
            if not isEnabled or sweepToken ~= currentToken then break end
            
            applyOptimization(descendants[i], char)
            count = count + 1
            
            if count % 1500 == 0 then
                RunService.Heartbeat:Wait()
            end
        end
    end)

    if not connections.descendantAdded then
        connections.descendantAdded = Workspace.DescendantAdded:Connect(function(v)
            if isEnabled and sweepToken == currentToken then
                applyOptimization(v, LocalPlayer.Character)
            end
        end)
    end
end

local function executeDisable(currentToken)
    isEnabled = false

    if connections.descendantAdded then
        connections.descendantAdded:Disconnect()
        connections.descendantAdded = nil
    end

    if cache.quality then
        settings().Rendering.QualityLevel = cache.quality
    end

    for k, v in pairs(cache.lighting) do
        Lighting[k] = v
    end
    table.clear(cache.lighting)

    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        for k, v in pairs(cache.terrain) do
            terrain[k] = v
        end
    end
    table.clear(cache.terrain)

    for obj, props in pairs(cache.props) do
        if obj and obj.Parent then
            for propName, propValue in pairs(props) do
                obj[propName] = propValue
            end
        end
    end
    table.clear(cache.props)

    for obj, oldParent in pairs(cache.parents) do
        if obj and oldParent then
            obj.Parent = oldParent
        end
    end
    table.clear(cache.parents)

    for obj, oldState in pairs(cache.fx) do
        if obj then
            obj.Enabled = oldState
        end
    end
    table.clear(cache.fx)
end

local function processQueue()
    if isProcessing then return end
    isProcessing = true

    while targetState ~= isEnabled do
        sweepToken = sweepToken + 1
        local currentToken = sweepToken
        
        if targetState then
            executeEnable(currentToken)
        else
            executeDisable(currentToken)
        end
    end

    isProcessing = false
end

function Optimizer.Toggle(state)
    local newState = state and true or false
    if targetState == newState then return end
    targetState = newState
    task.spawn(processQueue)
end

function Optimizer.Enable()
    Optimizer.Toggle(true)
end

function Optimizer.Disable()
    Optimizer.Toggle(false)
end

return Optimizer
