local Optimizer = {}

local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local isEnabled = false
local targetState = false
local isProcessing = false
local sweepToken = 0
local activeWorker = nil
local connections = {}

-- Secure local cache tables with weak keys to completely prevent memory leaks
local cache = {
    props = {},
    surfaces = {},
    fx = {},
    lighting = {},
    terrain = {},
    quality = nil
}

setmetatable(cache.props, {__mode = "k"})
setmetatable(cache.surfaces, {__mode = "k"})
setmetatable(cache.fx, {__mode = "k"})

-- Helper to ensure we never tamper with player characters, tools, or core gameplay elements
local function isExcluded(v)
    if not v then return true end
    
    -- Exclude local player character and items
    local char = LocalPlayer.Character
    if char and (v == char or v:IsDescendantOf(char)) then
        return true
    end
    
    -- Exclude Camera and UI/Core elements
    if v:IsA("Camera") or v:IsDescendantOf(Workspace:FindFirstChild("Camera")) then
        return true
    end

    return false
end

local function applyOptimization(v, currentToken)
    if not isEnabled or sweepToken ~= currentToken or isExcluded(v) then return end

    if v:IsA("BasePart") then
        if not cache.props[v] then
            cache.props[v] = {
                Material = v.Material,
                Reflectance = v.Reflectance,
                CastShadow = v.CastShadow
            }
        end
        pcall(function()
            if v.Material ~= Enum.Material.SmoothPlastic and v.Material ~= Enum.Material.Plastic then
                v.Material = Enum.Material.SmoothPlastic
            end
            v.Reflectance = 0
            v.CastShadow = false
        end)

    elseif v:IsA("SurfaceAppearance") then
        if not cache.surfaces[v] then
            cache.surfaces[v] = v.Parent
        end
        pcall(function() v.Parent = nil end)

    elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
        if cache.fx[v] == nil then
            cache.fx[v] = v.Enabled
        end
        pcall(function() v.Enabled = false end)

    elseif v:IsA("Decal") or v:IsA("Texture") then
        if not cache.props[v] then
            cache.props[v] = { Transparency = v.Transparency }
        end
        pcall(function() v.Transparency = 1 end)
        
    elseif v:IsA("PostEffect") or v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") or v:IsA("ColorCorrectionEffect") or v:IsA("Atmosphere") or v:IsA("Sky") then
        if cache.fx[v] == nil then
            if v:IsA("Sky") or v:IsA("Atmosphere") then
                cache.fx[v] = v.Parent
                pcall(function() v.Parent = nil end)
            else
                cache.fx[v] = v.Enabled
                pcall(function() v.Enabled = false end)
            end
        end
    end
end

local function executeEnable(currentToken)
    isEnabled = true

    pcall(function()
        if cache.quality == nil then
            cache.quality = settings().Rendering.QualityLevel
        end
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)

    if next(cache.lighting) == nil then
        cache.lighting = {
            GlobalShadows = Lighting.GlobalShadows,
            EnvironmentSpecularScale = Lighting.EnvironmentSpecularScale,
            EnvironmentDiffuseScale = Lighting.EnvironmentDiffuseScale
        }
    end

    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.EnvironmentSpecularScale = 0
        Lighting.EnvironmentDiffuseScale = 0
    end)

    for _, v in pairs(Lighting:GetChildren()) do
        applyOptimization(v, currentToken)
    end

    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain and next(cache.terrain) == nil then
        cache.terrain = {
            WaterWaveSize = terrain.WaterWaveSize,
            WaterWaveSpeed = terrain.WaterWaveSpeed,
            WaterReflectance = terrain.WaterReflectance,
            WaterTransparency = terrain.WaterTransparency
        }
        pcall(function()
            terrain.WaterWaveSize = 0
            terrain.WaterWaveSpeed = 0
            terrain.WaterReflectance = 0
            terrain.WaterTransparency = 0
        end)
    end

    if not connections.descendantAdded then
        connections.descendantAdded = Workspace.DescendantAdded:Connect(function(v)
            if isEnabled and sweepToken == currentToken then
                task.spawn(function()
                    applyOptimization(v, currentToken)
                end)
            end
        end)
    end

    -- High-performance, time-sliced non-blocking traversal using an iterator stack
    -- This prevents lag spikes/freezes on massive maps by budgeting execution time per frame.
    activeWorker = task.spawn(function()
        local stack = Workspace:GetChildren()
        while #stack > 0 and isEnabled and sweepToken == currentToken do
            local budget = os.clock() + 0.003 -- 3ms frame budget to maintain smooth 60+ FPS
            while #stack > 0 and os.clock() < budget and sweepToken == currentToken do
                local node = table.remove(stack)
                if node then
                    applyOptimization(node, currentToken)
                    if node.Parent ~= nil then
                        for _, child in ipairs(node:GetChildren()) do
                            table.insert(stack, child)
                        end
                    end
                end
            end
            if #stack > 0 and sweepToken == currentToken then
                task.wait()
            end
        end
    end)
end

local function executeDisable(currentToken)
    sweepToken = currentToken
    isEnabled = false

    if activeWorker then
        pcall(function() task.cancel(activeWorker) end)
        activeWorker = nil
    end

    if connections.descendantAdded then
        pcall(function() connections.descendantAdded:Disconnect() end)
        connections.descendantAdded = nil
    end

    pcall(function()
        if cache.quality then
            settings().Rendering.QualityLevel = cache.quality
        end
    end)

    for k, v in pairs(cache.lighting) do
        pcall(function() Lighting[k] = v end)
    end
    table.clear(cache.lighting)

    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        for k, v in pairs(cache.terrain) do
            pcall(function() terrain[k] = v end)
        end
    end
    table.clear(cache.terrain)

    for obj, props in pairs(cache.props) do
        if obj and obj.Parent then
            for propName, propValue in pairs(props) do
                pcall(function() obj[propName] = propValue end)
            end
        end
    end
    table.clear(cache.props)

    for obj, oldParent in pairs(cache.surfaces) do
        if obj and oldParent then
            pcall(function() obj.Parent = oldParent end)
        end
    end
    table.clear(cache.surfaces)

    for obj, oldState in pairs(cache.fx) do
        if obj then
            pcall(function() 
                if type(oldState) == "boolean" then
                    obj.Enabled = oldState
                else
                    obj.Parent = oldState 
                end
            end)
        end
    end
    table.clear(cache.fx)
end

local function processQueue()
    if isProcessing then return end
    isProcessing = true

    while targetState ~= isEnabled do
        sweepToken = sweepToken + 1
        local currentToken = sweepToken
        
        if targetState then
            executeEnable(currentToken)
        else
            executeDisable(currentToken)
        end
        task.wait(0.05)
    end

    isProcessing = false
end

function Optimizer.Toggle(state)
    local newState = state and true or false
    if targetState == newState then return end
    targetState = newState
    task.spawn(processQueue)
end

function Optimizer.Enable()
    Optimizer.Toggle(true)
end

function Optimizer.Disable()
    Optimizer.Toggle(false)
end

return Optimizer
