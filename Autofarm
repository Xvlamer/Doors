local antiAfkConn = nil
local function setAntiAFK(enabled)
    state.AntiAFK = enabled
    pcall(function() if type(saveState) == "function" then saveState() end end)
    
    if enabled then
        pcall(function()
            if getconnections then
                for _, conn in pairs(getconnections(P.Idled)) do
                    conn:Disable()
                end
            end
        end)
        
        if not antiAfkConn then
            antiAfkConn = trackConnection(P.Idled:Connect(function()
                pcall(function()
                    if VU then
                        VU:CaptureController()
                        VU:ClickButton2(Vector2.new())
                    end
                end)
            end))
        end
    else
        pcall(function()
            if getconnections then
                for _, conn in pairs(getconnections(P.Idled)) do
                    conn:Enable()
                end
            end
        end)
        
        if antiAfkConn then 
            pcall(function() antiAfkConn:Disconnect() end)
            antiAfkConn = nil 
        end
    end
end

