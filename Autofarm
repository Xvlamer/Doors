    local confirmBtn = create("TextButton", {Size=UDim2.new(1, -30, 0, 32), Position=UDim2.new(0, 15, 0, 102), BackgroundColor3=THEME_PURPLE, Font=Enum.Font.GothamBold, Text="Confirm", TextColor3=Color3.fromRGB(255, 255, 255), TextSize=11, AutoButtonColor=false, Parent=keyFrame})
    create("UICorner", {CornerRadius=UDim.new(0, 9), Parent=confirmBtn})

    local function handleKeyConfirm()
        if keyInput.Text == CORRECT_KEY then
            state.KeyExpiry = os.time() + 86400
            pcall(saveState)
            
            _G.XvlamerHub_CloseKeySystem()
            initializeMainHub()
        else
            errorLbl.Text = "Incorrect key! Verify with the script owner."
        end
    end
    trackConnection(confirmBtn.MouseButton1Click:Connect(handleKeyConfirm))
end

if state.KeyExpiry and os.time() < state.KeyExpiry then
    initializeMainHub()
else
    startKeySystem()
end
