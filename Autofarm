local function showStartupAutofarmPrompt(onComplete)
    if pendingStartupFarm then
        local savedStartupFarm = pendingStartupFarm
        pendingStartupFarm = nil
        
        if savedStartupFarm ~= "Stardust Farm" then
            if onComplete then onComplete(nil) end
            return
        end
        
        local countdown = (savedStartupFarm == "Stardust Farm") and 5 or nil
        
        showPopupModal(
            "XvlamersStartupAutofarmPrompt",
            string.format("⚙️ %s", string.upper(savedStartupFarm)),
            string.format("Would you like to proceed with the %s or cancel it?", savedStartupFarm),
            "Cancel",
            "Proceed",
            function()
                if onComplete then onComplete(nil) end
            end,
            function()
                if onComplete then onComplete(savedStartupFarm) end
            end,
            countdown
        )
    else
        if onComplete then onComplete(nil) end
    end
end

