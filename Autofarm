local Optimizer = {}
do
    local isEnabled, targetState, isProcessing, sweepToken = false, false, false, 0
    local connections = {}
    local cache = { props = {}, surfaces = {}, fx = {}, lighting = {}, terrain = {}, quality = nil }
    setmetatable(cache.props, {__mode = "k"})
    setmetatable(cache.surfaces, {__mode = "k"})
    setmetatable(cache.fx, {__mode = "k"})

    local smoothPlastic = Enum.Material.SmoothPlastic
    local camera = Workspace:FindFirstChildOfClass("Camera")

    local function isExcluded(v, char)
        if not v then return true end
        if char and (v == char or v:IsDescendantOf(char)) then return true end
        if v == camera or (camera and v:IsDescendantOf(camera)) then return true end
        if v.ClassName == "Tool" or v:FindFirstAncestorOfClass("Tool") then return true end
        return false
    end

    local function applyOptimization(v, char)
        if not isEnabled or isExcluded(v, char) then return end
        pcall(function()
            local className = v.ClassName
            if className == "Part" or className == "MeshPart" or className == "UnionOperation" or className == "CornerWedgePart" or className == "WedgePart" then
                if not cache.props[v] then 
                    cache.props[v] = { Reflectance = v.Reflectance, Material = v.Material, CastShadow = v.CastShadow, Color = v.Color, Transparency = v.Transparency } 
                end
                v.Reflectance = 0
                v.CastShadow = false
                if v.Material ~= smoothPlastic then v.Material = smoothPlastic end
            elseif className == "SurfaceAppearance" then
                if cache.surfaces[v] == nil then cache.surfaces[v] = v.Parent end
                v.Parent = nil
            elseif className == "Decal" or className == "Texture" then
                if cache.props[v] == nil then cache.props[v] = { Transparency = v.Transparency, Parent = v.Parent } end
                v.Transparency = 1
                v.Parent = nil
            elseif className == "PostEffect" or className == "BloomEffect" or className == "BlurEffect" or className == "SunRaysEffect" or className == "DepthOfFieldEffect" or className == "ColorCorrectionEffect" then
                if cache.fx[v] == nil then
                    cache.fx[v] = v.Enabled
                    v.Enabled = false
                end
            end
        end)
    end

    local function executeEnable(currentToken)
        isEnabled = true
        camera = Workspace:FindFirstChildOfClass("Camera")
        pcall(function() 
            if cache.quality == nil then cache.quality = settings().Rendering.QualityLevel end
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 
        end)

        if next(cache.lighting) == nil then 
            cache.lighting = { GlobalShadows = Lighting.GlobalShadows, EnvironmentSpecularScale = Lighting.EnvironmentSpecularScale, EnvironmentDiffuseScale = Lighting.EnvironmentDiffuseScale, Brightness = Lighting.Brightness, OutdoorAmbient = Lighting.OutdoorAmbient, FogEnd = Lighting.FogEnd, FogStart = Lighting.FogStart } 
        end

        pcall(function() 
            Lighting.GlobalShadows = false
            Lighting.EnvironmentSpecularScale = 0
            Lighting.EnvironmentDiffuseScale = 0
            Lighting.Brightness = 2
            Lighting.FogEnd = 999999
            Lighting.FogStart = 999999
        end)

        for _, v in pairs(Lighting:GetChildren()) do 
            if v.ClassName ~= "Sky" then applyOptimization(v, nil) end 
        end

        local terrain = Workspace:FindFirstChildOfClass("Terrain")
        if terrain and next(cache.terrain) == nil then
            cache.terrain = { WaterWaveSize = terrain.WaterWaveSize, WaterWaveSpeed = terrain.WaterWaveSpeed, WaterReflectance = terrain.WaterReflectance, WaterTransparency = terrain.WaterTransparency, Decoration = terrain.Decoration }
            pcall(function() 
                terrain.WaterWaveSize = 0
                terrain.WaterWaveSpeed = 0
                terrain.WaterReflectance = 0
                terrain.WaterTransparency = 0
                terrain.Decoration = false
            end)
        end

        local char = P.Character
        local descendants = Workspace:GetDescendants()
        task.spawn(function()
            for i = 1, #descendants do
                if not isEnabled or sweepToken ~= currentToken then break end
                applyOptimization(descendants[i], char)
            end
        end)

        if not connections.descendantAdded then 
            connections.descendantAdded = Workspace.DescendantAdded:Connect(function(v) 
                if isEnabled and sweepToken == currentToken then 
                    applyOptimization(v, P.Character) 
                end 
            end) 
        end
    end

    local function executeDisable(currentToken)
        sweepToken = currentToken
        isEnabled = false
        if connections.descendantAdded then 
            pcall(function() connections.descendantAdded:Disconnect() end)
            connections.descendantAdded = nil 
        end
        pcall(function() if cache.quality then settings().Rendering.QualityLevel = cache.quality end end)
        for k, v in pairs(cache.lighting) do pcall(function() Lighting[k] = v end) end
        table.clear(cache.lighting)

        local terrain = Workspace:FindFirstChildOfClass("Terrain")
        if terrain then for k, v in pairs(cache.terrain) do pcall(function() terrain[k] = v end) end end
        table.clear(cache.terrain)
        
        for obj, props in pairs(cache.props) do 
            if obj then 
                if props.Parent and not obj.Parent then pcall(function() obj.Parent = props.Parent end) end
                for propName, propValue in pairs(props) do if propName ~= "Parent" then pcall(function() obj[propName] = propValue end) end end 
            end 
        end 
        table.clear(cache.props)
        
        for obj, oldParent in pairs(cache.surfaces) do if obj and oldParent then pcall(function() obj.Parent = oldParent end) end end 
        table.clear(cache.surfaces)
        
        for obj, oldState in pairs(cache.fx) do if obj then pcall(function() obj.Enabled = oldState end) end end 
        table.clear(cache.fx)
    end

    local function processQueue()
        if isProcessing then return end
        isProcessing = true
        while targetState ~= isEnabled do
            sweepToken = sweepToken + 1
            local currentToken = sweepToken
            if targetState then executeEnable(currentToken) else executeDisable(currentToken) end
        end
        isProcessing = false
    end

    function Optimizer.Toggle(stateVal) 
        targetState = stateVal and true or false
        task.spawn(processQueue) 
    end
    function Optimizer.Disable() 
        targetState = false
        task.spawn(processQueue) 
    end
end

