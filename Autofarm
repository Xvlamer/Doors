    local function executeRawScript(key)
        local url = ""
        if key == "Knob Farm" then
            url = "https://raw.githubusercontent.com/Xvlamer/Doors/refs/heads/main/Autofarm%20Knobs"
        elseif key == "Death Farm" then
            url = "https://raw.githubusercontent.com/Xvlamer/Doors/refs/heads/main/Autofarm%20Deaths"
        elseif key == "Stardust Farm" then
            url = "https://raw.githubusercontent.com/Xvlamer/Doors/refs/heads/main/Autofarm%20Stardust"
        elseif key == "V-Clip (V)" or key == "VClip" then
            url = "https://raw.githubusercontent.com/Xvlamer/Doors/refs/heads/main/V-Clip%20(V)"
        elseif key == "V-Clip (V) Spam" or key == "VClipSpam" then
            url = "https://raw.githubusercontent.com/Xvlamer/Doors/refs/heads/main/V-Clip%20(V)%20Spam"
        end
        
        if url ~= "" then
            local success, res = pcall(function()
                return game:HttpGet(url)
            end)
            if success and res then
                local fn, compileErr = loadstring(res)
                if fn then
                    local runSuccess, runErr = pcall(fn)
                    if not runSuccess then
                        warn("[Xvlamers Hub] Runtime error in " .. key .. ": " .. tostring(runErr))
                        pcall(function() StarterGui:SetCore("SendNotification", {Title = "Xvlamers Hub", Text = key .. " crashed: " .. tostring(runErr), Duration = 5}) end)
                    end
                else
                    warn("[Xvlamers Hub] Compile error in " .. key .. ": " .. tostring(compileErr))
                    pcall(function() StarterGui:SetCore("SendNotification", {Title = "Xvlamers Hub", Text = key .. " failed to compile.", Duration = 5}) end)
                end
            else
                warn("[Xvlamers Hub] HTTP error fetching " .. key)
                pcall(function() StarterGui:SetCore("SendNotification", {Title = "Xvlamers Hub", Text = "Failed to fetch " .. key .. " from GitHub.", Duration = 5}) end)
            end
        end
    end

    local function runThread(key)
        stopThread(key)
        if key == "Knob Farm" then getgenv().XvlamerStop_KnobFarm = false end
        if key == "Death Farm" then getgenv().XvlamerStop_DeathFarm = false end
        if key == "Stardust Farm" then getgenv().XvlamerStop_StardustFarm = false end

        activeThreads[key] = task.spawn(function()
            executeRawScript(key)
        end)
    end

    local function createToggle(name, parentPage, isRadio, stateKey, order)
        local box = create("TextButton", {Size=UDim2.new(1,0,0,48), BackgroundColor3=Color3.fromRGB(18, 18, 24), Text="", AutoButtonColor=false, LayoutOrder=order, Parent=parentPage})
        create("UICorner", {CornerRadius=UDim.new(0,10), Parent=box}); create("UIStroke", {Color=Color3.fromRGB(45, 45, 60), Transparency=0.2, Thickness=1, Parent=box})
        create("TextLabel", {Size=UDim2.new(1,-85,1,0), Position=UDim2.new(0,16,0,0), BackgroundTransparency=1, Font=Enum.Font.GothamSemibold, Text=name, TextColor3=Color3.fromRGB(245, 245, 255), TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, Parent=box})
        
        local tBg = create("Frame", {Size=UDim2.new(0,44,0,22), Position=UDim2.new(1,-60,0.5,-11), BackgroundColor3=Color3.fromRGB(35, 35, 46), Parent=box})
        create("UICorner", {CornerRadius=UDim.new(1,0), Parent=tBg})
        local tCirc = create("Frame", {Size=UDim2.new(0,16,0,16), Position=UDim2.new(0,3,0.5,-8), BackgroundColor3=Color3.fromRGB(255,255,255), BorderSizePixel=0, Parent=tBg})
        create("UICorner", {CornerRadius=UDim.new(1,0), Parent=tCirc})
        
        local on = false
        local function setVisual(onState)
            TS:Create(tBg, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = onState and THEME_PURPLE or Color3.fromRGB(35, 35, 46)}):Play()
            TS:Create(tCirc, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = onState and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)}):Play()
        end

        local toggleObj = {name = name, set = setVisual, get = function() return on end, setOff = function(v) on = v; setVisual(v) end}
        if isRadio then table.insert(radioToggles, toggleObj) end

        local function updateState(newState, skipWarning)
            on = newState
            setVisual(on)
            if isRadio then
                if on then
                    for _, r in ipairs(radioToggles) do if r.name ~= name and r.get() then r.setOff(false) end end
                    state.ActiveFarm = name
                    saveState()
                    runThread(name)
                else
                    if state.ActiveFarm == name then state.ActiveFarm = nil; saveState() end
                    stopThread(name)
                end
            else
                state[stateKey] = on; saveState()
                if stateKey == "Optimizations" then 
                    Optimizer.Toggle(on) 
                elseif stateKey == "AntiAFK" then 
                    setAntiAFK(on) 
                elseif stateKey == "UnlockFps" then 
                    setUnlockFPS(on) 
                else
                    if on then runThread(stateKey) else stopThread(stateKey) end
                end
            end
        end

        toggleObj.update = updateState
        if stateKey then toggleHandlers[stateKey] = toggleObj else toggleHandlers[name] = toggleObj end

        box.MouseButton1Click:Connect(function()
            if isRadio then
                if on then updateState(false) else updateState(true) end
            else
                if stateKey == "Optimizations" then if not on then updateState(true) end else updateState(not on) end
            end
        end)
        
        if not isRadio and state[stateKey] == true and stateKey ~= "Optimizations" then
            on = true; setVisual(true)
            if stateKey == "AntiAFK" then 
                setAntiAFK(true) 
            elseif stateKey == "UnlockFps" then 
                setUnlockFPS(true) 
            else 
                runThread(stateKey) 
            end
        end
    end

    createToggle("Knob Farm", pages[2], true, nil, 1)
    createToggle("Death Farm", pages[2], true, nil, 2)
    createToggle("Stardust Farm", pages[2], true, nil, 3)
    createToggle("V-Clip (V)", pages[3], false, "VClip", 1)
    createToggle("V-Clip (V) Spam", pages[3], false, "VClipSpam", 2)
    createToggle("Optimizations", pages[3], false, "Optimizations", 3)
    createToggle("Unlock fps", pages[3], false, "UnlockFps", 4)
    createToggle("Anti-AFK", pages[3], false, "AntiAFK", 5)

    if state.AntiAFK then setAntiAFK(true); if toggleHandlers["AntiAFK"] then toggleHandlers["AntiAFK"].update(true) end end
    if state.UnlockFps then setUnlockFPS(true); if toggleHandlers["UnlockFps"] then toggleHandlers["UnlockFps"].update(true) end end

    trackConnection(UIS.InputBegan:Connect(function(input, gameProcessed) if input.KeyCode == Enum.KeyCode.V then if toggleHandlers["VClip"] then toggleHandlers["VClip"].update(true) end end end))
    trackConnection(UIS.InputEnded:Connect(function(input, gameProcessed) if input.KeyCode == Enum.KeyCode.V then if toggleHandlers["VClip"] then toggleHandlers["VClip"].update(false) end end end))

    if state.ActiveFarm then
        local loadedFarm = state.ActiveFarm
        showPopupModal(
            "XvlamersStartupWarning",
            "⚠️ ACTIVE SCRIPT ON JOIN",
            "You had " .. loadedFarm .. " active in your previous session. Would you like to resume it now?",
            "Turn Off",
            "Resume",
            function() state.ActiveFarm = nil; saveState() end,
            function() if toggleHandlers[loadedFarm] then toggleHandlers[loadedFarm].update(true, true) end end
        )
    end
end

