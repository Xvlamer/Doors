    local function runThread(key)
        stopThread(key)
        if key == "Knob Farm" then
            getgenv().XvlamerStop_KnobFarm = false
            activeThreads[key] = task.spawn(function() pcall(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/Xvlamer/Doors/main/Knob%20Farm.lua"))() end) end)
        elseif key == "Death Farm" then
            getgenv().XvlamerStop_DeathFarm = false
            activeThreads[key] = task.spawn(function() pcall(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/Xvlamer/Doors/main/Death%20Farm.lua"))() end) end)
        elseif key == "Stardust Farm" then
            getgenv().XvlamerStop_StardustFarm = false
            activeThreads[key] = task.spawn(function() pcall(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/Xvlamer/Doors/main/Stardust%20Farm.lua"))() end) end)
        elseif key == "V-Clip" then
            setVClip(true)
        elseif key == "V-Clip Spam" then
            setVClipSpam(true)
        end
    end

    local function createToggle(name, parentPage, isRadio, isVClipRadio, stateKey, order, customHeight)
        local toggleHeight = customHeight or 38
        local box = create("TextButton", {Size=UDim2.new(1,0,0,toggleHeight), BackgroundColor3=Color3.fromRGB(18, 18, 24), Text="", AutoButtonColor=false, Active=true, LayoutOrder=order, Parent=parentPage})
        create("UICorner", {CornerRadius=UDim.new(0,9), Parent=box}); create("UIStroke", {Color=Color3.fromRGB(45, 45, 60), Transparency=0.2, Thickness=1, Parent=box})
        
        local titleLbl = create("TextLabel", {Size=UDim2.new(1,-70,1,0), Position=UDim2.new(0,12,0,0), BackgroundTransparency=1, Active=false, Font=Enum.Font.GothamBold, Text=name, TextColor3=Color3.fromRGB(245, 245, 255), TextSize=11, TextXAlignment=Enum.TextXAlignment.Left, Parent=box})
        
        local tBg = create("Frame", {Size=UDim2.new(0,34,0,18), Position=UDim2.new(1,-46,0.5,-9), BackgroundColor3=Color3.fromRGB(35, 35, 46), Active=false, Parent=box})
        create("UICorner", {CornerRadius=UDim.new(1,0), Parent=tBg})
        local tCirc = create("Frame", {Size=UDim2.new(0,14,0,14), Position=UDim2.new(0,2,0.5,-7), BackgroundColor3=Color3.fromRGB(255,255,255), BorderSizePixel=0, Active=false, Parent=tBg})
        create("UICorner", {CornerRadius=UDim.new(1,0), Parent=tCirc})
        
        local on = false
        local function setVisual(onState)
            pcall(function()
                TS:Create(tBg, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = onState and THEME_PURPLE or Color3.fromRGB(35, 35, 46)}):Play()
                TS:Create(tCirc, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = onState and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)}):Play()
            end)
        end

        local toggleObj = {name = name, set = setVisual, get = function() return on end, setOff = function(v) on = v; setVisual(v) end}
        if isRadio then table.insert(radioToggles, toggleObj) end
        if isVClipRadio then table.insert(vclipRadioToggles, toggleObj) end

        local function updateState(newState, skipWarning)
            on = newState
            setVisual(on)
            
            if isRadio then
                if on then
                    if name == "Death Farm" and not skipWarning then
                        setVisual(false)
                        on = false
                        showPopupModal(
                            "XvlamersDeathFarmWarning",
                            "⚠️ DEATH FARM NOTICE",
                            "Death Farm utilizes deep hooks. Re-open Roblox after completing this farm to ensure stability.",
                            "Cancel",
                            "Proceed",
                            function() end,
                            function()
                                on = true
                                setVisual(true)
                                for _, r in ipairs(radioToggles) do if r.name ~= name and r.get() then r.setOff(false) end end
                                state.ActiveFarm = name
                                pcall(saveState)
                                runThread(name)
                            end
                        )
                        return
                    elseif name == "Knob Farm" and not skipWarning then
                        setVisual(false)
                        on = false
                        showPopupModal(
                            "XvlamersKnobFarmWarning",
                            "⚠️ LOBBY NOTICE",
                            "You should play in Mines with a 150% modifier boost.",
                            "Cancel",
                            "Proceed",
                            function() end,
                            function()
                                on = true
                                setVisual(true)
                                for _, r in ipairs(radioToggles) do if r.name ~= name and r.get() then r.setOff(false) end end
                                state.ActiveFarm = name
                                pcall(saveState)
                                runThread(name)
                            end
                        )
                        return
                    end

                    for _, r in ipairs(radioToggles) do 
                        if r.name ~= name and r.get() then 
                            r.setOff(false) 
                        end 
                    end
                    state.ActiveFarm = name
                    pcall(saveState)
                    runThread(name)
                else
                    if state.ActiveFarm == name then state.ActiveFarm = nil; pcall(saveState) end
                    stopThread(name)
                end
            elseif isVClipRadio then
                if on then
                    for _, r in ipairs(vclipRadioToggles) do
                        if r.name ~= name and r.get() then
                            r.setOff(false)
                        end
                    end
                    if stateKey then
                        state[stateKey] = true
                        if stateKey == "VClip" then state["VClipSpam"] = false else state["VClip"] = false end
                        pcall(saveState)
                    end
                    runThread(name)
                else
                    if stateKey then
                        state[stateKey] = false
                        pcall(saveState)
                    end
                    stopThread(name)
                end
            else
                if stateKey == "Optimizations" then
                    Optimizer.Toggle(on)
                elseif stateKey == "AntiAFK" then
                    setAntiAFK(on)
                elseif stateKey == "UnlockFps" then
                    setUnlockFPS(on)
                else
                    if on then runThread(name) else stopThread(name) end
                end
            end
        end

        toggleObj.update = updateState
        if isRadio then toggleHandlers[name] = toggleObj elseif stateKey then toggleHandlers[stateKey] = toggleObj else toggleHandlers[name] = toggleObj end

        local function triggerToggle()
            updateState(not on)
        end

        trackConnection(box.MouseButton1Click:Connect(triggerToggle))

        if isRadio and state.ActiveFarm == name then
            on = true
            setVisual(true)
            runThread(name)
        elseif stateKey and state[stateKey] == true then
            on = true
            setVisual(true)
            if stateKey == "Optimizations" then
                Optimizer.Toggle(true)
            elseif stateKey == "AntiAFK" then
                setAntiAFK(true)
            elseif stateKey == "UnlockFps" then
                setUnlockFPS(true)
            elseif stateKey == "VClip" then
                setVClip(true)
            elseif stateKey == "VClipSpam" then
                setVClipSpam(true)
            end
        end
    end

    createToggle("Knob Farm", pages[2], true, false, nil, 1, 36)
    createToggle("Death Farm", pages[2], true, false, nil, 2, 36)
    createToggle("Stardust Farm", pages[2], true, false, nil, 3, 36)

    createToggle("V-Clip", pages[3], false, true, "VClip", 1, 38)
    createToggle("V-Clip Spam", pages[3], false, true, "VClipSpam", 2, 38)
    createToggle("Optimizations", pages[3], false, false, "Optimizations", 3, 38)
    createToggle("Unlock fps", pages[3], false, false, "UnlockFps", 4, 38)
    createToggle("Anti-AFK", pages[3], false, false, "AntiAFK", 5, 38)
end

