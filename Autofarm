local Optimizer = {}
do
    local isEnabled, targetState, isProcessing, sweepToken = false, false, false, 0
    local connections = {}
    local cache = { props = {}, surfaces = {}, fx = {}, lighting = {}, terrain = {}, quality = nil }
    setmetatable(cache.props, {__mode = "k"}); setmetatable(cache.surfaces, {__mode = "k"}); setmetatable(cache.fx, {__mode = "k"})

    local function applyOptimization(v)
        if not isEnabled then return end
        pcall(function()
            if v:IsA("BasePart") then
                if not cache.props[v] then cache.props[v] = { Reflectance = v.Reflectance, Material = v.Material, CastShadow = v.CastShadow } end
                v.Reflectance = 0; v.CastShadow = false; if v.Material ~= Enum.Material.SmoothPlastic and v.Material ~= Enum.Material.Plastic then v.Material = Enum.Material.SmoothPlastic end
            elseif v:IsA("SurfaceAppearance") then
                if not cache.surfaces[v] then cache.surfaces[v] = v.Parent end
                v.Parent = nil
            elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
                if cache.fx[v] == nil then cache.fx[v] = v.Enabled end
                v.Enabled = false
            elseif v:IsA("Decal") or v:IsA("Texture") then
                if not cache.props[v] then cache.props[v] = { Transparency = v.Transparency } end
                v.Transparency = 1
            elseif v:IsA("PostEffect") or v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") or v:IsA("ColorCorrectionEffect") or v:IsA("Atmosphere") or v:IsA("Sky") then
                if cache.fx[v] == nil then
                    if v:IsA("Sky") or v:IsA("Atmosphere") then cache.fx[v] = v.Parent; v.Parent = nil
                    else cache.fx[v] = v.Enabled; v.Enabled = false end
                end
            end
        end)
    end

    local function executeEnable(currentToken)
        isEnabled = true
        pcall(function() if cache.quality == nil then cache.quality = settings().Rendering.QualityLevel end; settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
        if next(cache.lighting) == nil then cache.lighting = { GlobalShadows = Lighting.GlobalShadows, EnvironmentSpecularScale = Lighting.EnvironmentSpecularScale, EnvironmentDiffuseScale = Lighting.EnvironmentDiffuseScale } end
        pcall(function() Lighting.GlobalShadows = false; Lighting.EnvironmentSpecularScale = 0; Lighting.EnvironmentDiffuseScale = 0 end)
        for _, v in pairs(Lighting:GetChildren()) do applyOptimization(v) end
        local terrain = Workspace:FindFirstChildOfClass("Terrain")
        if terrain and next(cache.terrain) == nil then
            cache.terrain = { WaterWaveSize = terrain.WaterWaveSize, WaterWaveSpeed = terrain.WaterWaveSpeed, WaterReflectance = terrain.WaterReflectance, WaterTransparency = terrain.WaterTransparency }
            pcall(function() terrain.WaterWaveSize = 0; terrain.WaterWaveSpeed = 0; terrain.WaterReflectance = 0; terrain.WaterTransparency = 0 end)
        end
        if not connections.descendantAdded then connections.descendantAdded = Workspace.DescendantAdded:Connect(function(v) if isEnabled then applyOptimization(v) end end) end
        local stack = Workspace:GetChildren()
        task.spawn(function()
            while #stack > 0 and isEnabled and sweepToken == currentToken do
                local budget = os.clock() + 0.005 
                while #stack > 0 and os.clock() < budget and sweepToken == currentToken do
                    local node = table.remove(stack)
                    if node then applyOptimization(node); if node.Parent ~= nil then for _, child in ipairs(node:GetChildren()) do table.insert(stack, child) end end end
                end
                if #stack > 0 and sweepToken == currentToken then task.wait() end
            end
        end)
    end

    local function executeDisable(currentToken)
        sweepToken = currentToken; isEnabled = false
        if connections.descendantAdded then pcall(function() connections.descendantAdded:Disconnect() end); connections.descendantAdded = nil end
        pcall(function() if cache.quality then settings().Rendering.QualityLevel = cache.quality end end)
        for k, v in pairs(cache.lighting) do pcall(function() Lighting[k] = v end) end; table.clear(cache.lighting)
        local terrain = Workspace:FindFirstChildOfClass("Terrain")
        if terrain then for k, v in pairs(cache.terrain) do pcall(function() terrain[k] = v end) end end; table.clear(cache.terrain)
        for obj, props in pairs(cache.props) do if obj and obj.Parent then for propName, propValue in pairs(props) do pcall(function() obj[propName] = propValue end) end end end; table.clear(cache.props)
        for obj, oldParent in pairs(cache.surfaces) do if obj and oldParent then pcall(function() obj.Parent = oldParent end) end end; table.clear(cache.surfaces)
        for obj, oldState in pairs(cache.fx) do if obj then pcall(function() if type(oldState) == "boolean" then obj.Enabled = oldState else obj.Parent = oldState end end) end end; table.clear(cache.fx)
    end

    local function processQueue()
        if isProcessing then return end
        isProcessing = true
        while targetState ~= isEnabled do
            sweepToken = sweepToken + 1
            local currentToken = sweepToken
            if targetState then executeEnable(currentToken) else executeDisable(currentToken) end
            task.wait(0.01)
        end
        isProcessing = false
    end

    function Optimizer.Toggle(stateVal) targetState = stateVal and true or false; task.spawn(processQueue) end
    function Optimizer.Disable() targetState = false; task.spawn(processQueue) end
end

