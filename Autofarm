local function purgePhantomGUIs()
    pcall(function()
        local pg = P:FindFirstChild("PlayerGui")
        if pg then
            for _, v in pairs(pg:GetChildren()) do
                if v:IsA("ScreenGui") and not v.Name:match("Xvlamers") then
                    local hasPhantom = false
                    for _, desc in pairs(v:GetDescendants()) do
                        if desc:IsA("TextLabel") and desc.Text and desc.Text:match("You must run this in%-game") then
                            hasPhantom = true
                            break
                        end
                    end
                    if hasPhantom then v:Destroy() end
                end
            end
        end
    end)
end

