        create("TextLabel", {Size=UDim2.new(1,-70,1,0), Position=UDim2.new(0,12,0,0), BackgroundTransparency=1, Active=false, Font=Enum.Font.GothamBold, Text=name, TextColor3=Color3.fromRGB(245, 245, 255), TextSize=11, TextXAlignment=Enum.TextXAlignment.Left, Parent=box})
        
        local tBg = create("Frame", {Size=UDim2.new(0,34,0,18), Position=UDim2.new(1,-46,0.5,-9), BackgroundColor3=Color3.fromRGB(35, 35, 46), Active=false, Parent=box})
        create("UICorner", {CornerRadius=UDim.new(1,0), Parent=tBg})
        local tCirc = create("Frame", {Size=UDim2.new(0,14,0,14), Position=UDim2.new(0,2,0.5,-7), BackgroundColor3=Color3.fromRGB(255,255,255), BorderSizePixel=0, Active=false, Parent=tBg})
        create("UICorner", {CornerRadius=UDim.new(1,0), Parent=tCirc})
        
        local on = false
        local function setVisual(onState)
            pcall(function()
                TS:Create(tBg, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = onState and THEME_PURPLE or Color3.fromRGB(35, 35, 46)}):Play()
                TS:Create(tCirc, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = onState and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)}):Play()
            end)
        end

        local toggleObj = {
            name = name, 
            set = setVisual, 
            get = function() return on end, 
            setOff = function(v) 
                on = v
                setVisual(v)
                if isRadio then
                    if state.ActiveFarm == name then
                        state.ActiveFarm = nil
                        pcall(saveState)
                    end
                elseif not isVClipRadio and stateKey then
                    if state[stateKey] then
                        state[stateKey] = false
                        pcall(saveState)
                    end
                end
            end
        }
        if isRadio then table.insert(radioToggles, toggleObj) end
        if isVClipRadio then table.insert(vclipRadioToggles, toggleObj) end

        local function updateState(newState, skipWarning)
            on = newState
            setVisual(on)
            
            if isRadio then
                if on then
                    if name == "Knob Farm" and not skipWarning then
                        if isInLobby() then
                            setVisual(false)
                            on = false
                            if state.ActiveFarm == name then
                                state.ActiveFarm = nil
                                pcall(saveState)
                            end
                            showPopupModal(
                                "XvlamersModifiersPrompt",
                                "⚠️ 150% MODIFIERS",
                                "Use 150% Modifiers in the mines and collect the most gold for maximum Knobs.",
                                "",
                                "Proceed",
                                function() end,
                                function()
                                    setVisual(false)
                                    on = false
                                    if state.ActiveFarm == name then
                                        state.ActiveFarm = nil
                                        pcall(saveState)
                                    end
                                end
                            )
                            return
                        elseif getGoldValue() <= 0 then
                            setVisual(false)
                            on = false
                            if state.ActiveFarm == name then
                                state.ActiveFarm = nil
                                pcall(saveState)
                            end
                            showPopupModal(
                                "XvlamersZeroGoldWarning",
                                "⚠️ 0 GOLD",
                                "You have 0 gold collect more to start.",
                                "",
                                "Proceed",
                                function() end,
                                function()
                                    setVisual(false)
                                    on = false
                                    if state.ActiveFarm == name then
                                        state.ActiveFarm = nil
                                        pcall(saveState)
                                    end
                                end
                            )
                            return
                        else
                            for _, r in ipairs(radioToggles) do if r.name ~= name and r.get() then r.setOff(false) end end
                            state.ActiveFarm = name
                            pcall(saveState)
                            runThread(name)
                        end
                    elseif name == "Death Farm" and not skipWarning then
                        setVisual(false)
                        on = false
                        showPopupModal(
                            "XvlamersDeathFarmWarning",
                            "⚠️ DEATH FARM",
                            "Death farm uses advanced techniques for the most precision and speed and you must re open Roblox to completely stop it.",
                            "Cancel",
                            "Proceed",
                            function()
                                setVisual(false)
                                on = false
                                if state.ActiveFarm == name then
                                    state.ActiveFarm = nil
                                    pcall(saveState)
                                end
                            end,
                            function()
                                for _, r in ipairs(radioToggles) do if r.name ~= name and r.get() then r.setOff(false) end end
                                setVisual(true)
                                on = true
                                state.ActiveFarm = name
                                pcall(saveState)
                                runThread(name)
                            end
                        )
                    else
                        for _, r in ipairs(radioToggles) do if r.name ~= name and r.get() then r.setOff(false) end end
                        if name ~= "Knob Farm" then
                            state.ActiveFarm = name
                            pcall(saveState)
                        end
                        runThread(name)
                    end
                else
                    if state.ActiveFarm == name then state.ActiveFarm = nil; pcall(saveState) end
                    stopThread(name)
                end
            elseif isVClipRadio then
                if on then
                    for _, r in ipairs(vclipRadioToggles) do if r.name ~= name and r.get() then r.setOff(false) end end
                    runThread(name)
                else
                    stopThread(name)
                end
            else
                if stateKey then state[stateKey] = on; pcall(saveState) end
                if stateKey == "Optimizations" then Optimizer.Toggle(on)
                elseif stateKey == "AntiAFK" then setAntiAFK(on)
                elseif stateKey == "UnlockFps" then setUnlockFPS(on)
                else if on then runThread(name) else stopThread(name) end end
            end
        end

        toggleObj.update = updateState
        if isRadio then toggleHandlers[name] = toggleObj elseif stateKey then toggleHandlers[stateKey] = toggleObj else toggleHandlers[name] = toggleObj end

        trackConnection(box.MouseButton1Click:Connect(function() updateState(not on) end))

        if stateKey and state[stateKey] == true then
            on = true
            setVisual(true)
            if stateKey == "Optimizations" then Optimizer.Toggle(true)
            elseif stateKey == "AntiAFK" then setAntiAFK(true, true)
            elseif stateKey == "UnlockFps" then setUnlockFPS(true, true) end
        end
    end

