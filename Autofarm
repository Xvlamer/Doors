local wasMenuOnScreen = false
local savedMouseBehavior = Enum.MouseBehavior.LockCenter
local savedMouseIconEnabled = false

local mainRef = nil
local modalUnlockBtn = nil

local function updateCursorState()
    pcall(function()
        local isOnScreen = (mainRef and mainRef.Visible) or isModalOpen()
        
        if modalUnlockBtn then
            modalUnlockBtn.Visible = isOnScreen
            modalUnlockBtn.Modal = isOnScreen
            modalUnlockBtn.Active = isOnScreen
        end

        if isOnScreen then
            if not wasMenuOnScreen then
                if UIS.MouseBehavior ~= Enum.MouseBehavior.Default then
                    savedMouseBehavior = UIS.MouseBehavior
                end
                savedMouseIconEnabled = UIS.MouseIconEnabled
                wasMenuOnScreen = true
            end
            UIS.MouseBehavior = Enum.MouseBehavior.Default
            UIS.MouseIconEnabled = true
            GuiService.SelectedObject = modalUnlockBtn
        else
            if wasMenuOnScreen then
                wasMenuOnScreen = false
                UIS.MouseBehavior = savedMouseBehavior
                UIS.MouseIconEnabled = savedMouseIconEnabled
            end
            GuiService.SelectedObject = nil
        end
    end)
end

