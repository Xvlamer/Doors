        local tBg = create("Frame", {Size=UDim2.new(0,44,0,22), Position=UDim2.new(1,-60,0.5,-11), BackgroundColor3=Color3.fromRGB(35, 35, 46), Parent=box})
        create("UICorner", {CornerRadius=UDim.new(1,0), Parent=tBg})
        local tCirc = create("Frame", {Size=UDim2.new(0,16,0,16), Position=UDim2.new(0,3,0.5,-8), BackgroundColor3=Color3.fromRGB(255,255,255), BorderSizePixel=0, Parent=tBg})
        create("UICorner", {CornerRadius=UDim.new(1,0), Parent=tCirc})
        
        local on = false
        local function setVisual(onState)
            pcall(function()
                TS:Create(tBg, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = onState and THEME_PURPLE or Color3.fromRGB(35, 35, 46)}):Play()
                TS:Create(tCirc, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = onState and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)}):Play()
            end)
        end

        local isVClipPair = (name == "V-Clip" or name == "V-Clip Spam")
        local toggleObj = {name = name, set = setVisual, get = function() return on end, setOff = function(v) on = v; setVisual(v) end}
        if isRadio then table.insert(radioToggles, toggleObj) end
        if isVClipPair then table.insert(vclipToggles, toggleObj) end

        local function updateState(newState, skipWarning)
            on = newState
            setVisual(on)
            if isRadio or isVClipPair then
                if on then
                    if name == "Death Farm" and not skipWarning then
                        setVisual(false)
                        on = false
                        showPopupModal(
                            "XvlamersDeathFarmWarning",
                            "⚠️ DEATH FARM NOTICE",
                            "Death Farm utilizes deep hooks. Re-open Roblox after completing this farm to ensure stability.",
                            "Cancel",
                            "Proceed",
                            function() end,
                            function()
                                on = true
                                setVisual(true)
                                for _, r in ipairs(radioToggles) do if r.name ~= name and r.get() then r.setOff(false) end end
                                state.ActiveFarm = name
                                pcall(saveState)
                                runThread(name)
                            end
                        )
                        return
                    elseif name == "Knob Farm" and not skipWarning then
                        local coins = getPlayerCoins()
                        if coins <= 0 then
                            setVisual(false)
                            on = false
                            showPopupModal(
                                "XvlamersCoinWarning",
                                "⚠️ COINS REQUIRED",
                                "You have 0 coins! You must collect coins and not open the first door to start the script.",
                                "Cancel",
                                "Proceed",
                                function() end,
                                function()
                                    on = true
                                    setVisual(true)
                                    for _, r in ipairs(radioToggles) do if r.name ~= name and r.get() then r.setOff(false) end end
                                    state.ActiveFarm = name
                                    pcall(saveState)
                                    runThread(name)
                                end
                            )
                            return
                        elseif game.PlaceId == 6516141723 then
                            setVisual(false)
                            on = false
                            showPopupModal(
                                "XvlamersKnobFarmWarning",
                                "⚠️ KNOB FARM NOTICE",
                                "For maximum efficiency, make sure to select 'The Mines' and apply '150% Modifiers' before starting.",
                                "Cancel",
                                "Proceed",
                                function() end,
                                function()
                                    on = true
                                    setVisual(true)
                                    for _, r in ipairs(radioToggles) do if r.name ~= name and r.get() then r.setOff(false) end end
                                    state.ActiveFarm = name
                                    pcall(saveState)
                                    runThread(name)
                                end
                            )
                            return
                        end
                    end

                    local targetList = isRadio and radioToggles or vclipToggles
                    for _, r in ipairs(targetList) do 
                        if r.name ~= name and r.get() then 
                            r.setOff(false) 
                            if isVClipPair then
                                stopThread(r.name)
                            end
                        end 
                    end

                    if isRadio then
                        state.ActiveFarm = name
                        pcall(saveState)
                    end
                    runThread(name)
                else
                    if isRadio and state.ActiveFarm == name then state.ActiveFarm = nil; pcall(saveState) end
                    stopThread(name)
                end
            else
                state[stateKey] = on; pcall(saveState)
                if stateKey == "Optimizations" then 
                    Optimizer.Toggle(on) 
                elseif stateKey == "AntiAFK" then 
                    setAntiAFK(on) 
                elseif stateKey == "UnlockFps" then 
                    setUnlockFPS(on) 
                else
                    if on then runThread(name) else stopThread(name) end
                end
            end
        end

        toggleObj.update = updateState
        if stateKey then toggleHandlers[stateKey] = toggleObj else toggleHandlers[name] = toggleObj end

        box.MouseButton1Click:Connect(function()
            if isRadio or isVClipPair then
                if on then updateState(false) else updateState(true) end
            else
                if stateKey == "Optimizations" then if not on then updateState(true) end else updateState(not on) end
            end
        end)
        
        if not isRadio and not isVClipPair and state[stateKey] == true and stateKey ~= "Optimizations" then
            on = true; setVisual(true)
            if stateKey == "AntiAFK" then 
                setAntiAFK(true) 
            elseif stateKey == "UnlockFps" then 
                setUnlockFPS(true) 
            else 
                runThread(name) 
            end
        end
    end

    createToggle("Knob Farm", pages[2], true, nil, 1)
    createToggle("Death Farm", pages[2], true, nil, 2)
    createToggle("Stardust Farm", pages[2], true, nil, 3)

    createToggle("V-Clip", pages[3], false, "VClip", 1)
