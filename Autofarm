    local function createToggle(name, parentPage, isRadio, isVClipRadio, stateKey, order, customHeight)
        local toggleHeight = customHeight or 36
        local box = create("TextButton", {Size=UDim2.new(1,0,0,toggleHeight), BackgroundColor3=Color3.fromRGB(18, 18, 24), Text="", AutoButtonColor=false, Active=true, LayoutOrder=order, Parent=parentPage})
