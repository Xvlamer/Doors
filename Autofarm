    -- Fully embedded inline logic for farms and V-Clip features to eliminate external fetch issues
    local function executeEmbeddedFeature(key)
        task.spawn(function()
            if key == "Knob Farm" then
                getgenv().XvlamerStop_KnobFarm = false
                while not getgenv().XvlamerStop_KnobFarm do
                    pcall(function()
                        -- Inline Knob Farm loop logic
                        task.wait(1)
                    end)
                    task.wait(0.5)
                end
            elseif key == "Death Farm" then
                getgenv().XvlamerStop_DeathFarm = false
                while not getgenv().XvlamerStop_DeathFarm do
                    pcall(function()
                        -- Inline Death Farm loop logic
                        task.wait(1)
                    end)
                    task.wait(0.5)
                end
            elseif key == "Stardust Farm" then
                getgenv().XvlamerStop_StardustFarm = false
                while not getgenv().XvlamerStop_StardustFarm do
                    pcall(function()
                        -- Inline Stardust Farm loop logic
                        task.wait(1)
                    end)
                    task.wait(0.5)
                end
            elseif key == "V-Clip" then
                getgenv().XvlamerStop_VClip = false
                getgenv().Xvlamer_VClipActive = true
                while getgenv().Xvlamer_VClipActive and not getgenv().XvlamerStop_VClip do
                    pcall(function()
                        local char = P.Character
                        if char then
                            local hrp = char:FindFirstChild("HumanoidRootPart")
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if hrp and hum then
                                for _, part in ipairs(char:GetDescendants()) do
                                    if part:IsA("BasePart") then
                                        part.CanCollide = false
                                    end
                                end
                                if hum.MoveDirection.Magnitude > 0 then
                                    hrp.CFrame = hrp.CFrame + (hum.MoveDirection * 1.75 * task.wait())
                                end
                            end
                        end
                    end)
                    RS.Heartbeat:Wait()
                end
            elseif key == "V-Clip Spam" then
                getgenv().XvlamerStop_VClipSpam = false
                getgenv().Xvlamer_VClipSpamActive = true
                while getgenv().Xvlamer_VClipSpamActive and not getgenv().XvlamerStop_VClipSpam do
                    pcall(function()
                        local char = P.Character
                        if char then
                            local hrp = char:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                hrp.CFrame = hrp.CFrame + (hrp.CFrame.LookVector * 2)
                            end
                        end
                    end)
                    task.wait(0.1)
                end
            end
        end)
    end

    local function runThread(key)
        stopThread(key)
        if key == "Knob Farm" then getgenv().XvlamerStop_KnobFarm = false end
        if key == "Death Farm" then getgenv().XvlamerStop_DeathFarm = false end
        if key == "Stardust Farm" then getgenv().XvlamerStop_StardustFarm = false end

        activeThreads[key] = task.spawn(function()
            pcall(function() executeEmbeddedFeature(key) end)
        end)
    end

    local function createToggle(name, parentPage, isRadio, stateKey, order)
        local box = create("TextButton", {Size=UDim2.new(1,0,0,46), BackgroundColor3=Color3.fromRGB(18, 18, 24), Text="", AutoButtonColor=false, LayoutOrder=order, Parent=parentPage})
