local function getGoldValue()
    local goldVal = 0
    pcall(function()
        if P then
            local g = P:FindFirstChild("Gold")
            if not g and P:FindFirstChild("leaderstats") then
                g = P.leaderstats:FindFirstChild("Gold")
            end
            if not g then
                for _, desc in pairs(P:GetDescendants()) do
                    if desc.Name == "Gold" and (desc:IsA("IntValue") or desc:IsA("NumberValue")) then
                        g = desc
                        break
                    end
                end
            end
            if g and (g:IsA("IntValue") or g:IsA("NumberValue")) then
                goldVal = g.Value
            end
        end
    end)
    return goldVal
end

