local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local P = Players.LocalPlayer

-- Stop any previous running instance of this script
getgenv().XvlamerStop_VClipSpam = true
task.wait(0.1)
getgenv().XvlamerStop_VClipSpam = false

local lockedY = nil

task.spawn(function()
    while not getgenv().XvlamerStop_VClipSpam do
        pcall(function()
            local char = P.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                local cam = Workspace.CurrentCamera
                
                if hrp and cam and humanoid then
                    -- Lock onto the exact Y level when activated or stepping off an edge
                    if not lockedY then
                        lockedY = hrp.Position.Y
                    end
                    
                    -- Flatten the look vector for strictly horizontal movement (no falling or rising)
                    local look = cam.CFrame.LookVector
                    local flatLook = Vector3.new(look.X, 0, look.Z)
                    if flatLook.Magnitude > 0 then
                        flatLook = flatLook.Unit
                    else
                        flatLook = Vector3.new(0, 0, -1)
                    end
                    
                    -- Move forward horizontally while preserving the locked Y height
                    local currentPos = hrp.Position
                    local targetPos = Vector3.new(currentPos.X + (flatLook.X * 2.5), lockedY, currentPos.Z + (flatLook.Z * 2.5))
                    hrp.CFrame = CFrame.new(targetPos, targetPos + flatLook)
                    
                    -- Anti-cheat bypass: Force grounded running state and clear out velocity flags
                    humanoid:ChangeState(Enum.HumanoidStateType.Running)
                    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    
                    -- Noclip all parts
                    for _, part in ipairs(char:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end
        end)
        task.wait(0.05) -- Spams roughly 20 times a second
    end
end)
