local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

getgenv().Xvlamer_CustomClipRunning = not getgenv().Xvlamer_CustomClipRunning

local char = LocalPlayer.Character
local humanoid = char and char:FindFirstChildOfClass("Humanoid")
local rootPart = char and char:FindFirstChild("HumanoidRootPart")

if not getgenv().Xvlamer_CustomClipRunning then
    if getgenv().Xvlamer_CustomClipConn then
        getgenv().Xvlamer_CustomClipConn:Disconnect()
        getgenv().Xvlamer_CustomClipConn = nil
    end
    
    if char then
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = true
            end
        end
    end
    
    if humanoid then
        humanoid.WalkSpeed = getgenv().Xvlamer_OriginalWalkSpeed or 16
    end
    
    if rootPart then
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end
    return
end

if getgenv().Xvlamer_CustomClipConn then
    getgenv().Xvlamer_CustomClipConn:Disconnect()
end

if humanoid then
    getgenv().Xvlamer_OriginalWalkSpeed = humanoid.WalkSpeed
    humanoid.WalkSpeed = 0
end

local camera = workspace.CurrentCamera

getgenv().Xvlamer_CustomClipConn = RunService.Stepped:Connect(function(dt)
    local currentCharacter = LocalPlayer.Character
    if not currentCharacter then return end
    
    local currentRoot = currentCharacter:FindFirstChild("HumanoidRootPart")
    local currentHumanoid = currentCharacter:FindFirstChildOfClass("Humanoid")
    if not currentRoot or not currentHumanoid then return end

    currentHumanoid.WalkSpeed = 0

    for _, v in ipairs(currentCharacter:GetDescendants()) do
        if v:IsA("BasePart") then
            v.CanCollide = false
        end
    end

    local camLook = camera.CFrame.LookVector
    local flatLook = Vector3.new(camLook.X, 0, camLook.Z)
    if flatLook.Magnitude > 0 then
        flatLook = flatLook.Unit
    else
        flatLook = Vector3.new(0, 0, -1)
    end

    currentRoot.AssemblyLinearVelocity = Vector3.new(flatLook.X * 1.5, 0, flatLook.Z * 1.5)
    currentRoot.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
end)
