local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local P = Players.LocalPlayer

-- Clean up any previous running instances
getgenv().XvlamerStop_VClipSpam = true
task.wait(0.1)
getgenv().XvlamerStop_VClipSpam = false

local cam = Workspace.CurrentCamera
local connections = {}

-- Aggressive per-frame collision stripper (runs on Stepped before physics calculations)
table.insert(connections, RunService.Stepped:Connect(function()
    if getgenv().XvlamerStop_VClipSpam then return end
    
    local char = P.Character
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
                -- Disable touch/custom collision constraints if present
                if part.CustomPhysicalProperties then
                    part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
                end
            end
        end
    end
end))

-- High-frequency movement & anti-drift loop synchronized with Heartbeat
table.insert(connections, RunService.Heartbeat:Connect(function(dt)
    if getgenv().XvlamerStop_VClipSpam then
        for _, conn in ipairs(connections) do
            pcall(function() conn:Disconnect() end)
        end
        return
    end
    
    pcall(function()
        local char = P.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        
        if hrp and humanoid then
            -- Force character into a stable state to prevent ragdoll or anti-cheat state flags
            humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
            
            -- Read movement input or camera look vector for seamless directional gliding
            local look = cam.CFrame.LookVector
            local flatLook = Vector3.new(look.X, 0, look.Z)
            if flatLook.Magnitude > 0 then
                flatLook = flatLook.Unit
            else
                flatLook = Vector3.new(0, 0, -1)
            end
            
            -- Calculate movement velocity based on user input or forward vector
            local moveDir = humanoid.MoveDirection
            local velocityTarget = Vector3.new(0, 0, 0)
            
            if moveDir.Magnitude > 0 then
                velocityTarget = moveDir * 24 -- Adjust speed multiplier here if needed
            else
                velocityTarget = flatLook * 18
            end
            
            -- Apply velocity override while maintaining vertical stability
            hrp.AssemblyLinearVelocity = Vector3.new(velocityTarget.X, 0, velocityTarget.Z)
            hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        end
    end)
end))
