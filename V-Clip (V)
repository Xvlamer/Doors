local G = game
local RS = G:GetService("RunService")
local P = G:GetService("Players")

local lp = P.LocalPlayer

if getgenv().Xvlamer_VClipRunning then
    getgenv().XvlamerStop_VClip = true
    task.wait()
end

getgenv().XvlamerStop_VClip = false
getgenv().Xvlamer_VClipRunning = true

local char = lp.Character or lp.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")
local hrp = char:WaitForChild("HumanoidRootPart")

local oldSpeed = hum.WalkSpeed > 0 and hum.WalkSpeed or 16
local oldJump = hum.JumpPower > 0 and hum.JumpPower or 50
local oldHeight = hum.JumpHeight > 0 and hum.JumpHeight or 7.2
local oldPlatformStand = hum.PlatformStand
local oldAutoRotate = hum.AutoRotate

hum.WalkSpeed = 0
hum.JumpPower = 0
hum.JumpHeight = 0
hum.AutoRotate = false

local conns = {}
local vec0 = Vector3.zero
local physState = Enum.HumanoidStateType.Physics
local runningState = Enum.HumanoidStateType.Running
local lockedY = hrp.Position.Y

local cleanedUp = false
local function cleanup()
    if cleanedUp then return end
    cleanedUp = true
    
    for i = 1, #conns do
        pcall(function() conns[i]:Disconnect() end)
    end
    
    pcall(function()
        if char and char.Parent then
            local descendants = char:GetDescendants()
            for i = 1, #descendants do
                local part = descendants[i]
                if part:IsA("BasePart") then
                    part.CanCollide = true
                    part.Massless = false
                end
            end
        end
        if hrp and hrp.Parent then 
            hrp.AssemblyLinearVelocity = vec0 
            hrp.AssemblyAngularVelocity = vec0
        end
        if hum and hum.Parent then
            hum.PlatformStand = false
            hum.AutoRotate = true
            hum.WalkSpeed = oldSpeed
            hum.JumpPower = oldJump
            hum.JumpHeight = oldHeight
            hum:ChangeState(runningState)
        end
    end)
    
    getgenv().Xvlamer_VClipRunning = false
end

pcall(function()
    lockedY = hrp.Position.Y
    hum.PlatformStand = true
    hum:ChangeState(physState)
    
    local descendants = char:GetDescendants()
    for i = 1, #descendants do
        local part = descendants[i]
        if part:IsA("BasePart") then
            part.CanCollide = false
            part.Massless = true
        end
    end
end)

table.insert(conns, RS.Stepped:Connect(function()
    if getgenv().XvlamerStop_VClip then
        cleanup()
        return
    end
    if not char or not char.Parent or not hrp or not hum or hum.Health <= 0 then
        cleanup()
        return
    end

    hum.WalkSpeed = 0
    hum.JumpPower = 0
    hum.JumpHeight = 0
    hum.PlatformStand = true
    
    pcall(function() hum:ChangeState(physState) end)
    
    local descendants = char:GetDescendants()
    for i = 1, #descendants do
        local part = descendants[i]
        if part:IsA("BasePart") then
            part.CanCollide = false
            part.Massless = true
        end
    end
end))

table.insert(conns, RS.RenderStepped:Connect(function(dt)
    if getgenv().XvlamerStop_VClip then
        cleanup()
        return
    end
    if not hrp or not hrp.Parent then return end
    
    local lookDir = hrp.CFrame.LookVector
    local flatForward = Vector3.new(lookDir.X, 0, lookDir.Z)
    if flatForward.Magnitude > 0 then
        flatForward = flatForward.Unit
    end
    
    local currentPos = hrp.Position
    local nextPos = currentPos + (flatForward * 1.75 * dt)
    
    hrp.CFrame = CFrame.new(nextPos.X, lockedY, nextPos.Z) * CFrame.Angles(hrp.CFrame:ToEulerAnglesXYZ())
    hrp.AssemblyLinearVelocity = vec0
    hrp.AssemblyAngularVelocity = vec0
end))

table.insert(conns, RS.Heartbeat:Connect(function()
    if getgenv().XvlamerStop_VClip then
        cleanup()
    end
end))
