local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local P = Players.LocalPlayer

-- Stop any previous running instance of V-Clip
getgenv().XvlamerStop_VClip = true
task.wait(0.1)
getgenv().XvlamerStop_VClip = false

local connections = {}

-- Aggressive per-frame noclip to completely strip collisions every frame
table.insert(connections, RunService.Stepped:Connect(function()
    if getgenv().XvlamerStop_VClip then return end
    local char = P.Character
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end))

-- Smooth movement loop synchronized with Heartbeat
table.insert(connections, RunService.Heartbeat:Connect(function(dt)
    if getgenv().XvlamerStop_VClip then
        for _, conn in ipairs(connections) do
            pcall(function() conn:Disconnect() end)
        end
        return
    end
    
    pcall(function()
        local char = P.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        local cam = Workspace.CurrentCamera
        
        if hrp and cam and humanoid then
            humanoid:ChangeState(Enum.HumanoidStateType.Running)
            
            -- Smooth forward movement along camera look vector
            local look = cam.CFrame.LookVector
            local speed = 16
            hrp.CFrame = hrp.CFrame + (look * (speed * dt))
            
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        end
    end)
end))
