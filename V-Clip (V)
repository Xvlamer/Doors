-- V-Clip Loadstring Script
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

local function executeVClip()
    if not character or not humanoid or not rootPart or humanoid.Health <= 0 then 
        return 
    end

    -- Save current states and lock movement
    local oldWalkSpeed = humanoid.WalkSpeed
    local oldJumpPower = humanoid.JumpPower
    
    humanoid.WalkSpeed = 0
    humanoid.JumpPower = 0
    humanoid.PlatformStand = true

    -- Calculate target position (2 studs forward based on facing direction)
    local startCFrame = rootPart.CFrame
    local forwardVector = startCFrame.LookVector
    local targetCFrame = startCFrame + (forwardVector * 2)

    local duration = 0.25 -- Duration of the smooth glide in seconds
    local elapsed = 0
    local connection

    connection = RunService.RenderStepped:Connect(function(dt)
        elapsed = elapsed + dt
        local alpha = math.clamp(elapsed / duration, 0, 1)

        -- Smoothly interpolate position and zero out physics velocity
        rootPart.CFrame = startCFrame:Lerp(targetCFrame, alpha)
        rootPart.AssemblyLinearVelocity = Vector3.zero
        rootPart.AssemblyAngularVelocity = Vector3.zero

        if alpha >= 1 then
            connection:Disconnect()
            
            -- Restore original movement parameters
            humanoid.PlatformStand = false
            humanoid.WalkSpeed = oldWalkSpeed
            humanoid.JumpPower = oldJumpPower
        end
    end)
end

executeVClip()
