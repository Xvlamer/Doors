local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

-- Handle toggling state cleanly
if getgenv().Xvlamer_VClipRunning then
    getgenv().XvlamerStop_VClip = true
    task.wait(0.1)
end

getgenv().XvlamerStop_VClip = false
getgenv().Xvlamer_VClipRunning = true

local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Store original stats for restoration upon turning off
local originalWalkSpeed = humanoid.WalkSpeed
local originalJumpPower = humanoid.JumpPower
local originalJumpHeight = humanoid.JumpHeight

-- Strip walk and jump movement completely
humanoid.WalkSpeed = 0
humanoid.JumpPower = 0
humanoid.JumpHeight = 0

local connections = {}

-- Constant flow loop running every frame
local function onStepped(dt)
    if getgenv().XvlamerStop_VClip then
        return
    end
    
    if not character or not character.Parent or not rootPart or not humanoid or humanoid.Health <= 0 then
        return
    end

    -- Enforce stripped movement constraints continuously
    humanoid.WalkSpeed = 0
    humanoid.JumpPower = 0
    humanoid.JumpHeight = 0

    -- Enable wall noclip across all character parts
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end

    -- Constant forward float at 1.5 studs per second based on facing direction
    local lookVec = camera.CFrame.LookVector
    rootPart.CFrame = rootPart.CFrame + (lookVec * (1.5 * dt))
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
end

table.insert(connections, RunService.Stepped:Connect(onStepped))

-- Monitor stop flag
table.insert(connections, RunService.Heartbeat:Connect(function()
    if getgenv().XvlamerStop_VClip then
        for _, conn in ipairs(connections) do
            pcall(function() conn:Disconnect() end)
        end
        
        -- Restore original movement parameters
        pcall(function()
            if humanoid and humanoid.Parent then
                humanoid.WalkSpeed = originalWalkSpeed or 16
                humanoid.JumpPower = originalJumpPower or 50
                humanoid.JumpHeight = originalJumpHeight or 7.2
            end
        end)
        
        getgenv().Xvlamer_VClipRunning = false
    end
end))
