local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

if getgenv().Xvlamer_CustomClipRunning == nil then
    getgenv().Xvlamer_CustomClipRunning = false
end

getgenv().Xvlamer_CustomClipRunning = not getgenv().Xvlamer_CustomClipRunning

if not getgenv().Xvlamer_CustomClipRunning then
    if getgenv().Xvlamer_CustomClipConn then
        getgenv().Xvlamer_CustomClipConn:Disconnect()
        getgenv().Xvlamer_CustomClipConn = nil
    end

    local char = LocalPlayer.Character
    if char then
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = true
            end
        end

        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = getgenv().Xvlamer_SavedWalkSpeed or 16
        end
    end
    return
end

if getgenv().Xvlamer_CustomClipConn then
    getgenv().Xvlamer_CustomClipConn:Disconnect()
end

local initialChar = LocalPlayer.Character
if initialChar then
    local humanoid = initialChar:FindFirstChildOfClass("Humanoid")
    if humanoid then
        getgenv().Xvlamer_SavedWalkSpeed = humanoid.WalkSpeed ~= 5 and humanoid.WalkSpeed or 16
    end
end

getgenv().Xvlamer_CustomClipConn = RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end

    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.CanCollide = false
        end
    end

    humanoid.WalkSpeed = 5
end)
