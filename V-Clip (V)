local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

getgenv().XvlamerStop_VClip = false

local noclipConnection
noclipConnection = RunService.Stepped:Connect(function()
    if getgenv().XvlamerStop_VClip then
        if noclipConnection then noclipConnection:Disconnect() end
        local character = player.Character
        if character then
            for _, part in ipairs(character:GetChildren()) do
                if part:IsA("BasePart") then
                    if part.Name ~= "HumanoidRootPart" then
                        part.CanCollide = true
                    end
                end
            end
        end
        return
    end

    local character = player.Character
    if character then
        for _, part in ipairs(character:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

task.spawn(function()
    local character = player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")

    if character and humanoid and rootPart and humanoid.Health > 0 then
        local oldWalkSpeed = humanoid.WalkSpeed
        local oldJumpPower = humanoid.JumpPower
        
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0

        local startCFrame = rootPart.CFrame
        local targetCFrame = startCFrame + (startCFrame.LookVector * 1.5)
        
        local duration = 0.15
        local elapsed = 0
        while elapsed < duration and not getgenv().XvlamerStop_VClip do
            local dt = RunService.Heartbeat:Wait()
            elapsed = elapsed + dt
            local alpha = math.clamp(elapsed / duration, 0, 1)
            rootPart.CFrame = startCFrame:Lerp(targetCFrame, alpha)
            rootPart.AssemblyLinearVelocity = Vector3.zero
            rootPart.AssemblyAngularVelocity = Vector3.zero
        end

        humanoid.WalkSpeed = oldWalkSpeed
        humanoid.JumpPower = oldJumpPower
    end
end)
